<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.westoncodeops.sample.controllers.TenantController"
      spacing="20" styleClass="modal-content" prefWidth="600" prefHeight="650">
    
    <!-- Modal Header -->
    <VBox spacing="5">
        <Label text="Add New Tenant" styleClass="modal-title"/>
        <Label text="Fill in the tenant information below" styleClass="section-subtitle"/>
    </VBox>
    
    <!-- Form Fields -->
    <GridPane hgap="15" vgap="15" VBox.vgrow="ALWAYS">
        <!-- First Name -->
        <Label text="First Name:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="firstNameField" promptText="Enter first name" 
                   GridPane.columnIndex="1" GridPane.rowIndex="0" prefWidth="250"/>
        
        <!-- Last Name -->
        <Label text="Last Name:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="lastNameField" promptText="Enter last name" 
                   GridPane.columnIndex="1" GridPane.rowIndex="1" prefWidth="250"/>
        
        <!-- Email -->
        <Label text="Email:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <TextField fx:id="emailField" promptText="tenant@example.com" 
                   GridPane.columnIndex="1" GridPane.rowIndex="2" prefWidth="250"/>
        
        <!-- Phone Number -->
        <Label text="Phone Number:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
        <TextField fx:id="phoneField" promptText="254712345678" 
                   GridPane.columnIndex="1" GridPane.rowIndex="3" prefWidth="250"/>
        
        <!-- National ID -->
        <Label text="National ID:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
        <TextField fx:id="nationalIdField" promptText="Enter national ID number" 
                   GridPane.columnIndex="1" GridPane.rowIndex="4" prefWidth="250"/>
        
        <!-- Password -->
        <Label text="Password:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
        <PasswordField fx:id="passwordField" promptText="Enter password" 
                       GridPane.columnIndex="1" GridPane.rowIndex="5" prefWidth="250"/>
        
        <!-- Confirm Password -->
        <Label text="Confirm Password:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
        <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password" 
                       GridPane.columnIndex="1" GridPane.rowIndex="6" prefWidth="250"/>
        
        <!-- Role -->
        <Label text="Role:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
        <ComboBox fx:id="roleComboBox" promptText="Select role" 
                  GridPane.columnIndex="1" GridPane.rowIndex="7" prefWidth="250"/>
    </GridPane>
    
    <!-- Status Message -->
    <Label fx:id="statusLabel" text="" styleClass="label-small" wrapText="true"/>
    
    <!-- Action Buttons -->
    <HBox spacing="15" alignment="CENTER_RIGHT">
        <Button text="Cancel" styleClass="button-secondary" onAction="#closeModal" prefWidth="120"/>
        <Button fx:id="saveButton" text="Save Tenant" styleClass="button-primary" 
                onAction="#saveTenant" prefWidth="120"/>
    </HBox>
    
</VBox>

