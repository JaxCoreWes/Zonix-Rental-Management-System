<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!-- Made with Bob -->

<VBox spacing="20" styleClass="content-area" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.westoncodeops.sample.controllers.ExtensionController">
    
    <!-- Header Section with Actions -->
    <VBox spacing="15" styleClass="content-card">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox HBox.hgrow="ALWAYS">
                <Label styleClass="section-title" text="Payment Extensions" />
                <Label styleClass="section-subtitle" text="Review and approve tenant promise-to-pay requests" />
            </VBox>
        </HBox>
        
        <!-- Search and Filter Bar -->
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="toolbar">
            <Label styleClass="form-label" text="Search:" />
            <TextField fx:id="searchField" onKeyReleased="#handleSearch" prefWidth="360" promptText="Search by tenant name or unit" styleClass="search-input" />
            <Button onAction="#handleSearch" styleClass="toolbar-button" text="Search" />
            <Button onAction="#loadExtensions" styleClass="toolbar-button" text="Refresh" />
            <Button onAction="#filterAll" styleClass="toolbar-button" text="All" />
        </HBox>
    </VBox>
    
    <!-- Extensions Table -->
    <VBox styleClass="content-card" VBox.vgrow="ALWAYS">
      <HBox alignment="CENTER" prefHeight="20.0" prefWidth="1162.0" styleClass="toolbar">
         <children>
               <Label styleClass="form-label" text="Status:" />
               <Button onAction="#filterApproved" styleClass="button-success" text="Approved" />
               <Button onAction="#filterPending" styleClass="button-warning" text="Pending" />
               <Button onAction="#filterRejected" styleClass="button-danger" text="Rejected" />
         </children>
      </HBox>
        <Label styleClass="section-title" text="All Extension Requests">
            <padding>
                <Insets bottom="15" />
            </padding>
        </Label>
        
        <TableView fx:id="extensionsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" prefWidth="60" text="ID" visible="false" />
                <TableColumn fx:id="tenantNameColumn" prefWidth="180" text="Tenant" />
                <TableColumn fx:id="unitNumberColumn" prefWidth="100" text="Unit" />
                <TableColumn fx:id="amountDueColumn" prefWidth="140" text="Amount Due (KES)" />
                <TableColumn fx:id="requestedDateColumn" prefWidth="130" text="Requested Date" />
                <TableColumn fx:id="promisedDateColumn" prefWidth="130" text="Promised Date" />
                <TableColumn fx:id="reasonColumn" prefWidth="200" text="Reason" />
                <TableColumn fx:id="statusColumn" prefWidth="100" text="Status" />
                <TableColumn fx:id="actionsColumn" prefWidth="180" text="Actions" />
            </columns>
            <placeholder>
                <Label text="No extension requests found." />
            </placeholder>
        </TableView>
        
        <!-- Table Footer with Stats -->
        <HBox alignment="CENTER_LEFT" spacing="20" styleClass="padding-small">
            <padding>
                <Insets top="15" />
            </padding>
            <Label fx:id="totalExtensionsLabel" styleClass="label-bold" text="Total Requests: 0" />
            <Label fx:id="pendingExtensionsLabel" style="-fx-text-fill: #F59E0B;" styleClass="label-bold" text="Pending: 0" />
            <Label fx:id="approvedExtensionsLabel" style="-fx-text-fill: #10B981;" styleClass="label-bold" text="Approved: 0" />
            <Label fx:id="rejectedExtensionsLabel" style="-fx-text-fill: #EF4444;" styleClass="label-bold" text="Rejected: 0" />
        </HBox>
    </VBox>
    
</VBox>
