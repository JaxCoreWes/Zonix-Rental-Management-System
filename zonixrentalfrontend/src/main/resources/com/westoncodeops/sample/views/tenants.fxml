<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.TextFlow?>


<VBox spacing="20" styleClass="content-area" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.westoncodeops.sample.controllers.TenantController">
    
          <!-- Header Section with Actions -->
    <VBox prefHeight="47.0" prefWidth="992.0" spacing="15" styleClass="content-card">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox HBox.hgrow="ALWAYS">
                <Label styleClass="section-title" text="Tenant Management" />
                <Label prefHeight="17.0" prefWidth="265.0" styleClass="section-subtitle" text="View and manage all registered tenants" />
            </VBox>
            <Button fx:id="addTenantBtn" onAction="#showAddTenantModal" styleClass="button-primary" text="+ Add Tenant" />
        </HBox>
        
              <!-- Search Bar -->
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="toolbar">
            <Label styleClass="form-label" text="Search:" />
            <TextField fx:id="searchField" onKeyReleased="#handleSearch" prefWidth="380" promptText="Search by name, email, or phone" styleClass="search-input" />
            <Button onAction="#handleSearch" styleClass="toolbar-button" text="Search" />
            <Button onAction="#loadTenants" styleClass="toolbar-button" text="Refresh" />
        </HBox>
    </VBox>
   <TextFlow>
      <children>
         <Label styleClass="label-bold" text="All Tenants">
            <padding>
               <Insets bottom="14.0" left="14.0" right="14.0" />
            </padding>
         </Label>
         <Label fx:id="totalTenantsLabel" styleClass="label-bold" text="Total Tenants: 0">
            <padding>
               <Insets right="14.0" />
            </padding>
         </Label>
         <Label fx:id="selectedTenantLabel" styleClass="label-small" text="Selected: None">
            <padding>
               <Insets top="14.0" />
            </padding>
         </Label>
      </children>
      <VBox.margin>
         <Insets />
      </VBox.margin>
   </TextFlow>
   <TableView fx:id="tenantsTable">
      <columns>
         <TableColumn fx:id="idColumn" prefWidth="60" text="ID" visible="false" />
         <TableColumn fx:id="firstNameColumn" prefWidth="150" text="First Name" />
         <TableColumn fx:id="lastNameColumn" prefWidth="150" text="Last Name" />
         <TableColumn fx:id="emailColumn" prefWidth="200" text="Email" />
         <TableColumn fx:id="phoneColumn" prefWidth="150" text="Phone Number" />
         <TableColumn fx:id="nationalIdColumn" prefWidth="120" text="National ID" />
         <TableColumn fx:id="roleColumn" prefWidth="100" text="Role" />
         <TableColumn fx:id="createdAtColumn" prefWidth="120" text="Created Date" />
      </columns>
      <placeholder>
         <Label text="No tenants found. Click 'Add Tenant' to register a new tenant." />
      </placeholder>
   </TableView>
    
             <!-- Tenants Table -->
    <VBox styleClass="content-card" VBox.vgrow="ALWAYS" />
    
      </VBox>
