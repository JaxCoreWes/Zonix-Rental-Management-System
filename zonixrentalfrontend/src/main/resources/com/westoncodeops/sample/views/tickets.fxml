<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.westoncodeops.sample.controllers.TicketController"
      spacing="20" styleClass="content-area">
    
    <!-- Header Section with Actions -->
    <VBox spacing="15" styleClass="content-card">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Maintenance Tickets" styleClass="section-title"/>
                <Label text="Manage caretaker tickets and maintenance requests" styleClass="section-subtitle"/>
            </VBox>
            <Button text="+ Create Ticket" styleClass="button-primary" onAction="#showCreateTicketDialog"/>
        </HBox>
        
        <!-- Search and Filter Bar -->
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="toolbar">
            <Label text="Search:" styleClass="form-label"/>
            <TextField fx:id="searchField" promptText="Search by title, unit, or category" 
                       prefWidth="360" onKeyReleased="#handleSearch" styleClass="search-input"/>
            <Button text="Search" styleClass="toolbar-button" onAction="#handleSearch"/>
            <Button text="Refresh" styleClass="toolbar-button" onAction="#loadTickets"/>
            <Label text="Status:" HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT" styleClass="form-label"/>
            <Button text="All" styleClass="toolbar-button" onAction="#filterAll"/>
            <Button text="Pending" styleClass="button-warning" onAction="#filterPending"/>
            <Button text="Resolved" styleClass="button-success" onAction="#filterResolved"/>
        </HBox>
    </VBox>
    
    <!-- Tickets Table -->
    <VBox VBox.vgrow="ALWAYS" styleClass="content-card">
        <Label text="All Maintenance Tickets" styleClass="section-title">
            <padding>
                <Insets bottom="15"/>
            </padding>
        </Label>
        
        <TableView fx:id="ticketsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60" visible="false"/>
                <TableColumn fx:id="titleColumn" text="Title" prefWidth="200"/>
                <TableColumn fx:id="categoryColumn" text="Category" prefWidth="120"/>
                <TableColumn fx:id="priorityColumn" text="Priority" prefWidth="100"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
                <TableColumn fx:id="unitNumberColumn" text="Unit" prefWidth="100"/>
                <TableColumn fx:id="reportedByColumn" text="Reported By" prefWidth="150"/>
                <TableColumn fx:id="assignedToColumn" text="Assigned To" prefWidth="150"/>
                <TableColumn fx:id="reportedDateColumn" text="Reported Date" prefWidth="120"/>
                <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="150"/>
            </columns>
            <placeholder>
                <Label text="No maintenance tickets found. Click 'Create Ticket' to add a new ticket."/>
            </placeholder>
        </TableView>
        
        <!-- Table Footer with Stats -->
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="padding-small">
            <padding>
                <Insets top="15"/>
            </padding>
            <Label fx:id="totalTicketsLabel" text="Total Tickets: 0" styleClass="label-bold"/>
            <Label fx:id="pendingTicketsLabel" text="Pending: 0" style="-fx-text-fill: #F59E0B;" styleClass="label-bold"/>
            <Label fx:id="resolvedTicketsLabel" text="Resolved: 0" style="-fx-text-fill: #10B981;" styleClass="label-bold"/>
        </HBox>
    </VBox>
    
</VBox>

