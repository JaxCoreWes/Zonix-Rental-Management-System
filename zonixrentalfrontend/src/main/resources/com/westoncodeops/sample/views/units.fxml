<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.westoncodeops.sample.controllers.UnitController"
      spacing="20" styleClass="content-area">
    
    <!-- Header Section with Actions -->
    <VBox spacing="15" styleClass="content-card">
        <HBox alignment="CENTER_LEFT" spacing="15">
            <VBox HBox.hgrow="ALWAYS">
                <Label text="Unit Management" styleClass="section-title"/>
                <Label text="Track apartment availability and tenant assignments" styleClass="section-subtitle"/>
            </VBox>
            <Button text="+ Add Unit" styleClass="button-primary" onAction="#showAddUnitDialog"/>
        </HBox>
        
        <!-- Search and Filter Bar -->
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="toolbar">
            <Label text="Search:" styleClass="form-label"/>
            <TextField fx:id="searchField" promptText="Search by unit number or type" 
                       prefWidth="320" onKeyReleased="#handleSearch" styleClass="search-input"/>
            <Button text="Search" styleClass="toolbar-button" onAction="#handleSearch"/>
            <Button text="Refresh" styleClass="toolbar-button" onAction="#loadUnits"/>
            <Label text="Filter:" HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT" styleClass="form-label"/>
            <Button text="All" styleClass="toolbar-button" onAction="#filterAll"/>
            <Button text="Available" styleClass="button-success" onAction="#filterAvailable"/>
            <Button text="Occupied" styleClass="button-danger" onAction="#filterOccupied"/>
        </HBox>
    </VBox>
    
    <!-- Units Table -->
    <VBox VBox.vgrow="ALWAYS" styleClass="content-card">
        <Label text="All Units" styleClass="section-title">
            <padding>
                <Insets bottom="15"/>
            </padding>
        </Label>
        
        <TableView fx:id="unitsTable" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="idColumn" text="ID" prefWidth="60" visible="false"/>
                <TableColumn fx:id="unitNumberColumn" text="Unit Number" prefWidth="120"/>
                <TableColumn fx:id="unitTypeColumn" text="Type" prefWidth="150"/>
                <TableColumn fx:id="rentAmountColumn" text="Rent Amount (KES)" prefWidth="150"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
                <TableColumn fx:id="tenantNameColumn" text="Tenant" prefWidth="200"/>
                <TableColumn fx:id="createdAtColumn" text="Created Date" prefWidth="120"/>
                <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="150"/>
            </columns>
            <placeholder>
                <Label text="No units found. Click 'Add Unit' to create a new unit."/>
            </placeholder>
        </TableView>
        
        <!-- Table Footer with Stats -->
        <HBox spacing="20" alignment="CENTER_LEFT" styleClass="padding-small">
            <padding>
                <Insets top="15"/>
            </padding>
            <Label fx:id="totalUnitsLabel" text="Total Units: 0" styleClass="label-bold"/>
            <Label fx:id="availableUnitsLabel" text="Available: 0" style="-fx-text-fill: #10B981;" styleClass="label-bold"/>
            <Label fx:id="occupiedUnitsLabel" text="Occupied: 0" style="-fx-text-fill: #EF4444;" styleClass="label-bold"/>
        </HBox>
    </VBox>
    
</VBox>

